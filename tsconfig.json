{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/app/signup/page.jsx",
    "src/app/login/page.jsx",
    "src/app/checkout/page.jsx",
    "src/Contexts/ProductsContext.jsx",
    "src/Contexts/MenuContext.jsx",
    "src/components/Hero.jsx",
    "src/app/cart/page.jsx",
    "src/app/profile/page.jsx",
    "src/app/Product/[id]/page.jsx",
    "src/components/ShowCase.jsx",
    "src/Contexts/AuthContext.jsx",
    "src/components/UpdateProfileSection.jsx",
    "src/components/OrderSection.jsx",
    "src/app/wshlist/page.jsx",
    "src/Contexts/WishlistContext.jsx",
    "src/Contexts/CartContext.jsx",
    "src/components/Products.jsx",
    "src/Contexts/AddOrdersContext.jsx",
    "src/components/Swipper.jsx",
    "src/components/ShopingAddresSection.jsx",
    "src/components/NewSletter.jsx",
    "src/components/Navbar.jsx",
    "src/components/FooterBottom.jsx",
    "src/app/Product/[id]/page.jsx",
    "src/components/ChangePasswordSection.jsx",
    "src/components/Footer.jsx",
    "src/components/G&R_Comments.jsx",
    "src/app/layout.jsx",
    "src/app/Product/[id]/page.jsx"
  ],
  "exclude": ["node_modules"]
}
